# Reference: paste into Railway service variables (use "Reference" for linked resources)

# ============ BACKEND ============
# Postgres — add reference: ${{Postgres.DATABASE_URL}}
# Or private: ${{Postgres.DATABASE_PRIVATE_URL}}

# Storage Bucket — use Railway "Add variable reference" → AWS SDK preset, or:
# ${{Bucket.BUCKET}}           → maps to S3 bucket name
# ${{Bucket.ENDPOINT}}         → https://storage.railway.app
# ${{Bucket.ACCESS_KEY_ID}}
# ${{Bucket.SECRET_ACCESS_KEY}}
# ${{Bucket.REGION}}

# App also reads: S3_BUCKET, AWS_S3_BUCKET_NAME, BUCKET (any one)

AUTO_BOOTSTRAP=true
GEMINI_API_KEY=
GROQ_API_KEY=

# ============ FRONTEND ============
# Private networking (service must be named "backend"):
BACKEND_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:${{backend.PORT}}

# Or public backend URL:
# BACKEND_URL=https://your-backend.up.railway.app
