# AI (optional for live Upload & Analyze)
GEMINI_API_KEY=
GROQ_API_KEY=

# Frontend nginx proxy target (Docker Compose / Railway)
BACKEND_URL=http://backend:8000

# PostgreSQL (Railway / Docker)
DATABASE_URL=postgresql://dicom_user:dicom_pass_2024@db:5432/dicom_ai

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO) ---
# Omit S3_BUCKET to use local disk (LOCAL_STORAGE_ROOT) for development.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Key prefixes inside the bucket
S3_DICOM_PREFIX=dicom/
S3_SHOWCASE_PREFIX=showcase/
S3_ANALYSIS_PREFIX=analysis/

# Local fallback when S3_BUCKET is unset (Docker Compose mounts ../data here)
LOCAL_STORAGE_ROOT=/data/raw
SHOWCASE_DATA_DIR=/showcase_data
ANALYSIS_OUTPUT_DIR=/analysis_output
